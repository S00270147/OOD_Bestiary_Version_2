<Window x:Class="OOD_Bestiary_Version_2.CharacterProfile"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:OOD_Bestiary_Version_2"
        mc:Ignorable="d"
        Title="CharacterProfile" Height="450" Width="800"
        WindowStartupLocation="CenterScreen">
    <Window.Background>
        <ImageBrush ImageSource="/images/BG.png"/>
    </Window.Background>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="51*"/>
            <ColumnDefinition Width="84*"/>
            <ColumnDefinition Width="65*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="204*"/>
            <RowDefinition Height="43*"/>
            <RowDefinition Height="43*"/>
            <RowDefinition Height="144*"/>
        </Grid.RowDefinitions>

        <Canvas Grid.ColumnSpan="3" Grid.RowSpan="4" Opacity="0.5">
            <Canvas.Background>
                <LinearGradientBrush EndPoint="0.5,1" StartPoint="0.5,0">
                    <GradientStop Color="Black" Offset="0.125"/>
                    <GradientStop Color="Transparent" Offset="0"/>
                </LinearGradientBrush>
            </Canvas.Background>


        </Canvas>

        <TextBlock Name="tblkDescription" TextWrapping="Wrap" Text="TextBlock" Foreground="White" Grid.Column="0" Grid.Row="2" Grid.ColumnSpan="2" Grid.RowSpan="2" Margin="10,0,120,10"/>
        <Image Name="imgChar" Grid.Column="0" Grid.Row="0" Margin="10,10,10,10"/>
        <TextBlock TextWrapping="Wrap" Text="Description:" Margin="10,0,0,0" Foreground="White" FontSize="25" Grid.Column="0" Grid.Row="1"/>
        <TextBlock TextWrapping="Wrap" Text="Speed:" Margin="220,0,0,0" Foreground="White" FontSize="25" Grid.Column="1" Grid.Row="1"/>
        <TextBlock TextWrapping="Wrap" Text="Diet:" Margin="220,0,0,0" Foreground="White" FontSize="25" Grid.Column="1" Grid.Row="2"/>
        <TextBlock TextWrapping="Wrap" Text="FoodPips:" Margin="220,0,0,0" Foreground="White" FontSize="25" Grid.Column="1" Grid.Row="3"/>
        <TextBlock x:Name="tblkCharacterName" TextWrapping="Wrap" Text="TextBlock" FontSize="48" Foreground="White" Grid.Column="1" Grid.ColumnSpan="2"  Margin="10,50,0,0" TextAlignment="Left"/>

        <TextBlock x:Name="tblkSpeed" TextWrapping="Wrap" Text="TextBlock" Foreground="White" FontSize="25" Grid.Column="2" Grid.Row="1"/>
        <TextBlock x:Name="tblkDiet" TextWrapping="Wrap" Text="TextBlock" Foreground="White" FontSize="25" Grid.Column="2" Grid.Row="2"/>
        <TextBlock x:Name="tblkFoodPips" TextWrapping="Wrap" Text="TextBlock" Foreground="White" FontSize="25" Grid.Column="2" Grid.Row="3"/>






    </Grid>
</Window>
